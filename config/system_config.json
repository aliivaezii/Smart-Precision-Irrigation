{
    "project_name": "Smart Precision Irrigation",
    "version": "2.0",
    "broker": {
        "address": "test.mosquitto.org",
        "port": 1883
    },
    "settings": {
        "lat": 45.06,
        "lon": 7.66,
        "rain_threshold_mm": 5.0
    },
    "devices": [
        {
            "device_id": "field_1_sensor",
            "device_type": "sensor_node",
            "name": "Field 1 Moisture Monitor",
            "topics": {
                "publish": "farm/field_1/telemetry",
                "subscribe": "farm/field_1/config"
            }
        },
        {
            "device_id": "field_1_valve",
            "device_type": "actuator_node",
            "name": "Field 1 Valve",
            "topics": {
                "publish": "farm/field_1/valve_status",
                "subscribe": "farm/field_1/valve_cmd"
            }
        }
    ]
}